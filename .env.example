# Required for local development and production builds.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required in production for Auth redirects (password reset, email confirm).
# Example: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=

# Optional. Glow Atlas map's PMTiles basemap (supporting geographic context
# only — never the source of interactive state geometry, see
# src/features/glow-atlas/data/geo/). Never left empty in production for the
# best visual result, but the map works without it: GlowMap always renders
# the local Australia/state GeoJSON + presence layers and shows a subtle
# status line if this URL is missing or fails to load.
#
# Production: point this at object storage/CDN with HTTP range-request
# support (e.g. a Supabase Storage public bucket or Cloudflare R2 bucket
# serving a `.pmtiles` file). Do NOT point production at a file inside this
# repo — the archive is gitignored and is never bundled into the deployment.
# Example: https://<project>.supabase.co/storage/v1/object/public/atlas/australia.pmtiles
#
# Local development: optionally point this at a small local fixture, e.g.
# a metro-only extract served from `public/atlas/` (gitignored — see
# src/features/glow-atlas/map/ATTRIBUTION.md for how to build one) or a
# `pmtiles://` URL to a file on disk. Leave empty to develop against the
# GeoJSON-only fallback.
# NEXT_PUBLIC_ATLAS_PMTILES_URL=

# Optional. Synthetic Atlas Preview — ~5,000 deterministic, seeded ambient
# lights spread around Australian population centres, purely to make the
# map feel visually alive while there are only a handful of real beta
# users. Entirely renderer-side (no database rows, no fake users) and
# entirely separate from real presence — see
# src/features/glow-atlas/map/syntheticAtlasData.ts for the full
# truthfulness rationale and generation algorithm. Whenever this is on, the
# map shows an explicit "Atlas preview · Simulated community density"
# disclosure outside the canvas — it is never labelled as real activity.
#
# Set to exactly "true" to enable (any other value, or leaving it unset,
# keeps the preview off — this is the same rule in every environment: local
# dev, preview/beta, and production all only ever turn it on when this is
# explicitly "true"). Never enable this in production once there is
# meaningful real presence to show instead.
# NEXT_PUBLIC_ATLAS_SYNTHETIC_PREVIEW=

# Optional. Overrides the default synthetic point count (5000). Clamped to
# a safe upper cap (see SYNTHETIC_PREVIEW_MAX_COUNT in
# src/features/glow-atlas/map/syntheticPreviewConfig.ts) regardless of what
# is set here.
# NEXT_PUBLIC_ATLAS_SYNTHETIC_PREVIEW_COUNT=

# Auto-set on Vercel preview/production — do not commit real values.
# VERCEL_URL=

# Never put SUPABASE_SERVICE_ROLE_KEY in NEXT_PUBLIC_* or client bundles.
# Auth before-user-created hook is configured in Supabase Dashboard (SQL function),
# not via a Next.js env secret.
